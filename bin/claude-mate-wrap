#!/usr/bin/env python3
"""
claude-mate-wrap — wrap `claude` in a PTY and report its live state.
=====================================================================

Run `claude` THROUGH this wrapper (alias claude=claude-mate-wrap). It:

  1. Forks a pseudo-terminal and runs the real `claude` inside it, relaying
     stdin/stdout transparently — you use Claude exactly as normal.
  2. Mirrors the full TUI into a headless terminal emulator (pyte) and reads the
     *current screen* every update, so it sees EVERYTHING: the spinner, API
     errors/retries, permission prompts, and "Waiting for N dynamic workflow to
     finish" (i.e. it knows the session is still busy after the turn "ends").
  3. Reports state changes to the Claude Mate daemon over its Unix socket, and
     auto-registers on start / removes on exit (the display mirrors your open
     wrapped terminals).
  4. Listens on a per-session control socket for window commands, auto-picking
     the method from $TERM_PROGRAM (iTerm2 / Terminal.app / VS Code / tmux /
     generic): 'focus' raises (and un-minimizes) THIS terminal window — sent on
     the FOCUS button and when the device's SCROLL card lands on this tab;
     'collapse' miniaturizes it — sent when the card moves on. Commands are
     acked in two stages — 'go' on receipt (liveness), 'ok' only after the
     window op completes — so the daemon can order window ops ACROSS sessions
     (unordered osascripts finish out of order and leave a stale terminal on
     top) without stalling long on a wedged wrapper.

State model (matches the daemon): working | waiting | error | idle
  working  TUI is generating, OR a background dynamic-workflow is still running.
  waiting  a permission prompt / question is on screen (needs your input).
  error    an API error / retry is visible.
  idle     at the prompt, nothing pending.

Config (env):
  CLAUDE_MATE_SOCK   daemon socket (default /tmp/claude-mate.sock)
  CLAUDE_MATE_DEBUG  if set to a path, append screen+state snapshots there
  CLAUDE_REAL        explicit path to the real `claude` binary (else autodetected)

Requires: pyte  (pip install pyte)
"""
import os, sys, pty, tty, termios, fcntl, struct, signal, select, socket, \
       threading, time, re, json, uuid, subprocess, shutil, atexit

try:
    import pyte
except ImportError:
    # Defer the fallback. The OLD code here did `os.execvp("claude", ...)`, but in
    # the global-shim deployment `claude` IS this wrapper -> it re-exec'd itself
    # forever (the "never block the user" path doing exactly that). main() instead
    # execs real_claude() -- the same shim-skipping resolver the wrapped path uses
    # -- before it touches anything pyte-dependent.
    pyte = None

# --------------------------------------------------------------------------- #
# Config / identity
# --------------------------------------------------------------------------- #
DAEMON_SOCK = os.environ.get("CLAUDE_MATE_SOCK", "/tmp/claude-mate.sock")
DEBUG = os.environ.get("CLAUDE_MATE_DEBUG")
SID = uuid.uuid4().hex[:8]
NAME = (os.path.basename(os.getcwd()) or "claude")[:20]
TERM_PROGRAM = os.environ.get("TERM_PROGRAM", "")
CTRL_SOCK = f"/tmp/claude-mate-ctrl-{SID}.sock"
TITLE = f"◆cm:{NAME}:{SID}"          # unique terminal title (generic-focus fallback)
try:
    MY_TTY = os.ttyname(0)           # this terminal's device — used for EXACT focus
except OSError:
    MY_TTY = ""

# --------------------------------------------------------------------------- #
# State-detection patterns. Case-insensitive substrings matched against the
# rendered screen. Defaults are deliberately TIGHT (only unambiguous signals) so
# incidental words don't false-trigger. Override LIVE — no restart — by editing
# the JSON at CLAUDE_MATE_PATTERNS (default: <repo>/patterns.json) with keys
# "error" / "waiting" / "busy" -> lists of substrings.
# --------------------------------------------------------------------------- #
DEFAULT_PATTERNS = {
    # STRONG error signals -- specific enough to match in the wider status region
    # (a real error box is multi-line). "api error" is Claude's own retry banner;
    # the others are unambiguous UI strings. (Bare "rate limit" / "rate_limit_error"
    # are deliberately NOT here: they are ordinary code/doc tokens that show up on
    # screen as content and would false-trigger the whole-screen scrape.)
    "error": [
        "api error", "overloaded_error",
        "service is temporarily",
        "usage limit reached",
    ],
    # CONTENT-PRONE error PHRASES -- specific enough to mean a real failure but
    # still possible in ordinary output, so matched ONLY in the tight live status
    # region (bottom BUSY_TAIL_LINES) and only when NOT actively working. Bare HTTP
    # status codes (" 500" etc.) are deliberately NOT here: they collide with the
    # live token meter ("↓ 500 tokens") and with any number on screen, reading as a
    # false 'error' that then nags every 5s. A genuine API error carries "api error"
    # (the strong list above) or one of these phrases.
    "error_footer": [
        "internal server error", "connection error", "request timed out",
    ],
    # Specific prompt text -- safe to match anywhere on the screen.
    "waiting": [
        "do you want to proceed", "yes, and don't ask",
        "tell claude what to do differently", "no, and tell claude",
        "press enter to continue",
    ],
    # Interactive option/menu picker footers (AskUserQuestion, file/option
    # selectors) mean WAITING for your choice -- e.g. "Enter to select ·
    # Tab/Arrow keys to navigate · Esc to cancel". These words are GENERIC, so
    # detect_state matches them ONLY in the footer (last few non-empty lines),
    # never against conversation/file content higher up the screen, AND a footer
    # match must PERSIST (WAITING_FOOTER_DEBOUNCE_S) before it reports as waiting.
    # NOTE: "esc to cancel" / "esc to go back" are intentionally absent -- the
    # /effort and /model sliders carry that footer, so matching it buzzed the
    # instant you opened one. A real question picker carries "to select" /
    # "to navigate"; those config sliders do not.
    "waiting_footer": [
        "to select", "to navigate",
    ],
    # Signals that appear ONLY when genuinely generating, OR when the turn has
    # "ended" but background work is still running: the interrupt hint ("esc to
    # interrupt", distinct from a picker's "esc to cancel"), the "running in the
    # background" footer, a pending dynamic workflow / tool, and a pending
    # background agent ("Waiting for N background agent(s) to finish" -- the
    # Explore/subagent status line, which carries no "esc to interrupt").
    "busy": [
        "esc to interrupt", "running in the background",
        "workflow to finish", "tool to finish",
        "background agent", "agent to finish",
    ],
}

_PATTERNS_FILE = os.environ.get(
    "CLAUDE_MATE_PATTERNS",
    os.path.join(os.path.dirname(os.path.dirname(os.path.realpath(__file__))),
                 "patterns.json"),
)
_patterns = {k: [s.lower() for s in v] for k, v in DEFAULT_PATTERNS.items()}
_patterns_mtime = [0.0]

def load_patterns():
    """Hot-reload patterns from the JSON file if it changed (live tuning)."""
    try:
        m = os.stat(_PATTERNS_FILE).st_mtime
    except OSError:
        return
    if m == _patterns_mtime[0]:
        return
    try:
        with open(_PATTERNS_FILE) as fh:
            data = json.load(fh)
    except (OSError, ValueError):
        return
    new = {k: [s.lower() for s in v] for k, v in DEFAULT_PATTERNS.items()}
    for k in ("error", "error_footer", "waiting", "waiting_footer", "busy"):
        if isinstance(data.get(k), list):
            new[k] = [str(x).lower() for x in data[k]]
    # Atomic publish: rebind the module-global to the freshly built dict in one
    # store, rather than clear()+update() (which a concurrent reader could observe
    # half-empty). Detection now runs on a single thread (see monitor()), but the
    # atomic swap keeps this correct regardless.
    global _patterns
    _patterns = new
    _patterns_mtime[0] = m

POLL_MS = 0.25            # re-evaluate the screen this often (quiescence)
DEBOUNCE_S = 0.30         # require a state to persist before reporting it
# A "waiting" detected ONLY from the generic option-picker footer must persist
# this long before we report it. A real AskUserQuestion/permission picker sits
# there until you answer; a config dialog you open and dismiss (/effort, /model,
# /config) is gone in ~1s -- so this debounce stops those transient pickers from
# buzzing while still catching genuine prompts (just ~2.5s later, which is fine
# for an away-from-keyboard alert). Specific waiting text (permission prompts)
# is unaffected -- it still reports at DEBOUNCE_S.
WAITING_FOOTER_DEBOUNCE_S = 2.5
KEEPALIVE_S = 20.0        # re-send current state periodically

# How many non-empty bottom lines count as Claude's "live status region". State
# signals (error/prompt/generating) are matched only here, so the same keywords
# in scrollback / logs / code / conversation above don't false-trigger.
STATUS_TAIL_LINES = 20    # error/waiting region (error boxes & permission prompts
                          # are genuinely multi-line, so they need the wider window)
BUSY_TAIL_LINES = 8       # tighter region for the live spinner: the generating meter,
                          # the 'esc to interrupt' hint, and background-agent notices
                          # only ever render on the bottom status line(s). A narrow
                          # window keeps a meter STRING quoted higher up in the
                          # conversation (e.g. these very design notes) from reading
                          # as "working" while the session is actually idle.
FOOTER_LINES = 4          # tighter region for the generic picker-footer phrases

# Claude's IDLE-at-prompt footer hint. It shows only when the session is waiting
# for input; a genuinely working frame -- foreground OR a running agents panel --
# shows "esc to interrupt" instead, never this. So when it is in the bottom footer
# we know the session is idle, and a spinner-SHAPED line elsewhere on screen (a
# pasted status line, docs/blockquotes about the meter, this repo's own test
# fixtures) is quoted content, not a live spinner -- it must not read as working.
_IDLE_FOOTER = ("? for shortcuts",)

# --------------------------------------------------------------------------- #
# Terminal size helpers
# --------------------------------------------------------------------------- #
def get_winsize(fd):
    try:
        data = fcntl.ioctl(fd, termios.TIOCGWINSZ, b"\0" * 8)
        rows, cols, _, _ = struct.unpack("HHHH", data)
        if rows and cols:
            return rows, cols
    except Exception:
        pass
    return 24, 80

def set_winsize(fd, rows, cols):
    try:
        fcntl.ioctl(fd, termios.TIOCSWINSZ, struct.pack("HHHH", rows, cols, 0, 0))
    except Exception:
        pass

# --------------------------------------------------------------------------- #
# Daemon reporting
# --------------------------------------------------------------------------- #
def send_daemon(state):
    """Best-effort one-line report to the daemon. Never raises.

    Wire format: state|SID|NAME|CTRL_SOCK|MODEL|EFFORT  (model/effort may be
    empty until captured from the screen; the daemon and firmware both treat
    the trailing fields as optional, so older peers stay compatible)."""
    model = g_meta["model"].replace("|", "/")
    effort = g_meta["effort"].replace("|", "/")
    try:
        c = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        c.settimeout(0.5)
        c.connect(DAEMON_SOCK)
        c.sendall(f"{state}|{SID}|{NAME}|{CTRL_SOCK}|{model}|{effort}\n".encode())
        c.close()
    except OSError:
        pass

# --------------------------------------------------------------------------- #
# Focus: raise THIS terminal window, method chosen from $TERM_PROGRAM
# --------------------------------------------------------------------------- #
def _osa(script):
    try:
        subprocess.run(["osascript", "-e", script],
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, timeout=4)
    except Exception:
        pass

def focus_self():
    # If we're inside tmux, also select our pane/window.
    pane = os.environ.get("TMUX_PANE")
    if os.environ.get("TMUX") and pane:
        for args in (["tmux", "select-window", "-t", pane],
                     ["tmux", "select-pane", "-t", pane]):
            try:
                subprocess.run(args, stdout=subprocess.DEVNULL,
                               stderr=subprocess.DEVNULL, timeout=3)
            except Exception:
                pass

    tp = TERM_PROGRAM.lower()
    if tp == "iterm.app":
        # Match the session by its TTY (exact), fall back to title. Restore the
        # window first in case the nav preview miniaturized it.
        _osa(f'''
            tell application "iTerm2"
              activate
              repeat with w in windows
                repeat with t in tabs of w
                  repeat with s in sessions of t
                    try
                      if (tty of s) is "{MY_TTY}" or (name of s contains "{TITLE}") then
                        set miniaturized of w to false
                        select w
                        tell t to select
                        select s
                        return
                      end if
                    end try
                  end repeat
                end repeat
              end repeat
            end tell''')
    elif tp == "apple_terminal":
        # Bring Terminal forward, then make THIS tab (matched by its TTY) the
        # selected, front window. Un-miniaturize first: the daemon's nav
        # preview may have collapsed this window to the Dock, and selecting a
        # tab of a miniaturized window would not restore it. (macOS raises an
        # app's windows as a group; we ensure ours ends up on top + focused.)
        _osa(f'''
            tell application "Terminal"
              activate
              repeat with w in windows
                repeat with t in tabs of w
                  try
                    if (tty of t) is "{MY_TTY}" then
                      set miniaturized of w to false
                      set selected of t to true
                      set frontmost of w to true
                      return
                    end if
                  end try
                end repeat
              end repeat
            end tell''')
    elif tp == "vscode":
        # Can't target a specific integrated-terminal pane externally; raise VS Code.
        _osa('tell application "Visual Studio Code" to activate')
    elif tp == "ghostty":
        _osa('tell application "Ghostty" to activate')
    elif tp in ("warpterminal", "warp"):
        _osa('tell application "Warp" to activate')
    else:
        # Generic: ask System Events to raise any window whose title matches
        # (un-minimizing it first in case the nav preview collapsed it).
        _osa(f'''
            tell application "System Events"
              set procs to (every process whose background only is false)
              repeat with p in procs
                repeat with w in (windows of p)
                  if name of w contains "{TITLE}" then
                    try
                      set value of attribute "AXMinimized" of w to false
                    end try
                    set frontmost of p to true
                    perform action "AXRaise" of w
                  end if
                end repeat
              end repeat
            end tell''')

def collapse_self():
    """Miniaturize THIS session's terminal window (the daemon's SCROLL-nav
    preview collapses the previously-shown tab as the card moves on).
    Best effort, mirrors focus_self()'s per-$TERM_PROGRAM matching. No-ops
    where a single pane can't be collapsed (tmux panes, VS Code integrated
    terminals) -- collapsing the whole shared window would hide innocent
    bystanders."""
    if os.environ.get("TMUX"):
        return                              # a tmux pane can't be miniaturized
    tp = TERM_PROGRAM.lower()
    if tp == "iterm.app":
        _osa(f'''
            tell application "iTerm2"
              repeat with w in windows
                repeat with t in tabs of w
                  repeat with s in sessions of t
                    try
                      if (tty of s) is "{MY_TTY}" or (name of s contains "{TITLE}") then
                        set miniaturized of w to true
                        return
                      end if
                    end try
                  end repeat
                end repeat
              end repeat
            end tell''')
    elif tp == "apple_terminal":
        _osa(f'''
            tell application "Terminal"
              repeat with w in windows
                repeat with t in tabs of w
                  try
                    if (tty of t) is "{MY_TTY}" then
                      set miniaturized of w to true
                      return
                    end if
                  end try
                end repeat
              end repeat
            end tell''')
    elif tp == "vscode":
        pass                                # can't collapse one integrated pane
    else:
        # Generic: minimize any window whose title matches ours.
        _osa(f'''
            tell application "System Events"
              set procs to (every process whose background only is false)
              repeat with p in procs
                repeat with w in (windows of p)
                  if name of w contains "{TITLE}" then
                    try
                      set value of attribute "AXMinimized" of w to true
                    end try
                  end if
                end repeat
              end repeat
            end tell''')

def ctrl_listener():
    """Per-session socket: the daemon connects and sends 'focus' (raise +
    un-minimize this terminal) or 'collapse' (miniaturize it). Two-stage
    reply: 'go' immediately on receipt (proves this wrapper is alive, so the
    daemon's short first wait doesn't burn its full op deadline on a wedged
    process), then 'ok' only AFTER the window op completes. The daemon holds
    one window-op lock across ALL sessions and waits for 'ok', so ops apply
    in exactly the order the device drove them -- fire-and-forget osascripts
    from different wrappers finish out of order, which left a stale terminal
    expanded (device card != laptop window)."""
    try:
        if os.path.exists(CTRL_SOCK):
            os.unlink(CTRL_SOCK)
        srv = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        srv.bind(CTRL_SOCK)
        os.chmod(CTRL_SOCK, 0o666)
        srv.listen(4)
    except OSError:
        return
    while True:
        try:
            conn, _ = srv.accept()
        except OSError:
            break
        try:
            try:
                data = conn.recv(64).decode(errors="ignore").strip()
            except OSError:
                data = ""
            known = data.startswith("focus") or data.startswith("collapse")
            if known:
                try:
                    conn.sendall(b"go\n")   # liveness: accepted, now running --
                except OSError:             # the daemon's short first wait ends
                    pass                    # here instead of at its op deadline
                if data.startswith("focus"):
                    focus_self()
                else:
                    collapse_self()
            try:
                conn.sendall(b"ok\n")       # ack: op done, the next one may run
            except OSError:
                pass
        finally:
            try:
                conn.close()
            except OSError:
                pass

# --------------------------------------------------------------------------- #
# Model + effort capture from the rendered screen
# --------------------------------------------------------------------------- #
# Claude's TUI shows the model and effort in a couple of reliable spots:
#   - the welcome box header line, e.g.
#       "│   Opus 4.8 (1M context) with xhigh · Claude Max ·   │"
#   - an effort "pill" above the prompt / in the /model dialog, e.g.
#       "◉ xhigh · /effort"   /   "◉ xHigh effort ←/→ to adjust"
# Neither is guaranteed to stay on-screen once a long conversation scrolls, so
# we capture opportunistically and CACHE the last seen values per session (the
# model is captured at boot from the welcome box; effort is refreshed whenever
# the pill is visible, e.g. after you change it). Both are scoped tightly so the
# same words appearing in ordinary conversation/code can't be mistaken for them:
#   - the model must sit on the welcome-box header line specifically: inside a
#     "│" border AND followed (same bordered segment) by the "Claude <plan>"
#     badge it always carries -- e.g. "│ Opus 4.8 (1M context) with xhigh ·
#     Claude Max · │". Requiring "Claude" rules out a bordered line that merely
#     mentions a model, e.g. a /model picker row "│ 2. Opus 4.8 · capable │" or a
#     markdown-table cell, which would otherwise overwrite the sticky cache.
#   - the effort must directly follow the "◉" pill glyph and be a known level.
_MODEL_RE = re.compile(
    r'│[^│\n]*?\b((?:Opus|Sonnet|Haiku|Fable)\s+[0-9.]+)\b[^│\n]*?claude', re.I)
_EFFORT_RE = re.compile(
    r'◉\s*(low|medium|high|xhigh|max|ultracode)\b', re.I)

# Last-known model/effort for THIS session (sticky cache).
g_meta = {"model": "", "effort": ""}

def parse_meta(screen_text):
    """Refresh g_meta from the current screen if model/effort are visible."""
    m = _MODEL_RE.search(screen_text)
    if m:
        g_meta["model"] = " ".join(m.group(1).split())   # collapse stray spaces
    e = _EFFORT_RE.search(screen_text)
    if e:
        g_meta["effort"] = e.group(1).lower()

# --------------------------------------------------------------------------- #
# State detection from the rendered screen
# --------------------------------------------------------------------------- #
# Claude Code's live ACTIVITY METER is shown in EVERY actively-working frame --
# while generating, running tools, AND during the extended-thinking phase -- e.g.
#   "✻ Forming… (14s · ↓ 610 tokens · thinking with xhigh effort)"
#   "✻ Herding…  (2m 3s · ↑ 1,204 tokens · esc to interrupt)"
# The spinner verb rotates and the "esc to interrupt" hint ROTATES OUT for a
# "Tip:" line every few seconds, so keying "working" off "esc to interrupt"
# alone mis-reads the thinking phase (and the tip frames) as idle -- which the
# daemon then turns into a premature DONE buzz mid-turn. The meter itself is the
# stable signal: an arrow+token counter, or an elapsed-timer parenthetical that
# also carries "tokens", or the "thinking with <effort> effort" suffix. All three
# are specific enough that ordinary prose rarely matches -- and because the live
# meter is matched only within the bottom BUSY_TAIL_LINES status region (see
# detect_state), a meter string QUOTED higher up in the conversation (such as in
# these comments) sits outside that window and no longer false-reads as "working".
_WORKING_METER_RE = re.compile(
    r'[↑↓]\s*[\d.,]+\s*[kKmM]?\s*tokens?\b'   # ↓ 610 tokens / ↓ 79.9k tokens / ↑ 1,204 tokens
    r'|\(\s*\d+\s*[hms]\b[^)\n]*\btokens?\b'  # (14s · … tokens …) / (1h 4m 30s · … tokens)
    r'|\bthinking with\s+\w+\s+effort\b',     # thinking with xhigh effort
    re.I)

# A LIVE SPINNER line, matched over the WHOLE visible screen (not just the bottom
# region). Claude renders one while generating AND while a background agent /
# workflow runs -- a spinner VERB ending in an ellipsis, then a parenthetical with
# a running elapsed timer and either an arrow token meter or the thinking hint:
#   "✻ Forming… (14s · ↓ 610 tokens · thinking with xhigh effort)"
#   "· Hatching… (5m 2s · ↓ 15.3k tokens)"       (a subagent spawning)
#   "✶ Working… (3s · ↑ 429 tokens · esc to interrupt)"
# When a background agent's transcript fills the screen BELOW it, that spinner sits
# ABOVE the bottom BUSY_TAIL_LINES window -- so keying "working" only off the bottom
# region mis-read a busy multi-agent session as idle (-> premature DONE).
#
# It stays quote-resistant WITHOUT a region limit via TWO structural requirements
# an adversarial review found necessary (a bare "glyph + timer + meter" match false-
# fired on markdown tables `| Opus | 2m 30s | ↓ 79.9k tokens |`, bulleted meter
# quotes `- … 3m 30s … ↓ 79.9k tokens`, and finished-agent recap rows):
#   1. a spinner VERB immediately followed by an ellipsis then "(<timer> …" -- prose,
#      tables, bullets and "○ … done · …" recaps have no "word…(timer" shape;
#   2. it must sit at the LINE START (only optional indent + one spinner glyph) --
#      so a spinner string QUOTED mid-sentence ('the meter reads "✻ Forming… (14s…)"')
#      is not at a line start and does not match.
_LIVE_SPINNER_RE = re.compile(
    r'^[ \t]*[^\w\s]?[ \t]*'                   # line start: optional indent + one glyph
    r'\w+[ \t]*(?:…|\.\.\.)[ \t]*'             # a spinner verb + ellipsis: "Forming…"
    r'\(\s*\d+\s*[hms]\b[^)\n]*?'              # "(14s …" / "(1h 4m …" running elapsed timer
    r'(?:[↑↓]\s*[\d.,]+\s*[kKmM]?\s*tokens?'   # … then an arrow token meter, OR
    r'|thinking with\s+\w+\s+effort)',         # … the thinking-effort hint
    re.I | re.M)

# Claude's END-OF-TURN BACKGROUND-WORK banner. The foreground reply has finished
# (the prompt is available again) but real work is STILL running -- a dynamic
# workflow, background agents, or a tool. Claude shows a live line like
#   "Waiting for 1 dynamic workflow to finish"
#   "Waiting for 2 background agents to finish"
# that CLEARS the instant the work completes, so it is a trustworthy "still
# working" tell. Two things make it different from the foreground spinner, and
# both matter here:
#   1. it can sit FAR above the bottom region -- the task panel + the prompt box
#      push it up, well outside BUSY_TAIL_LINES -- so it is matched over the WHOLE
#      screen (this is exactly why a genuinely-busy session was mis-read idle ->
#      premature DONE);
#   2. it COEXISTS with the idle prompt ("? for shortcuts" shows while background
#      work runs), so it must NOT be suppressed by the idle-prompt gate.
# Quote-resistance is structural instead: it must sit at a LINE START (optional
# indent + one glyph) and match the exact "Waiting for <N> ... to finish" shape,
# so prose about background work ("still waiting for the agent to finish") never
# fires -- there is no leading count, or "waiting" is not the first word.
_BG_WORK_RE = re.compile(
    r'^[ \t]*[^\w\s]?[ \t]*'                   # line start: optional indent + one glyph
    r'waiting for\s+\d+\s+'                    # "Waiting for 1 " (a live count)
    r'[^\n]*?\bto finish\b',                   # "... dynamic workflow / agents / tool to finish"
    re.I | re.M)

def detect_state(screen_text):
    # Read only Claude's LIVE STATUS REGION (the bottom of the visible screen),
    # not the whole scrollback. Error/prompt/generating chrome renders there, so
    # the same keywords appearing in conversation / logs / code / file content
    # higher up no longer false-trigger the state.
    #
    # Returns (state, source). `source` lets evaluate() debounce a footer-only
    # "waiting" (generic picker) longer than a specific permission prompt, so a
    # config dialog you open and dismiss can't buzz.
    nonblank = [ln for ln in screen_text.splitlines() if ln.strip()]
    tail = "\n".join(nonblank[-STATUS_TAIL_LINES:]).lower()
    busy_tail = "\n".join(nonblank[-BUSY_TAIL_LINES:]).lower()
    footer = "\n".join(nonblank[-FOOTER_LINES:]).lower()
    full = "\n".join(nonblank)               # whole visible screen (for live lines)

    # Is the session actively working? Two signals:
    #  1. The live activity meter / "esc to interrupt" / background-work hints in
    #     the bottom BUSY_TAIL_LINES region (the normal foreground spinner spot).
    #  2. A glyph-prefixed LIVE status/agent line ANYWHERE on screen -- a running
    #     agent panel pushes the spinner above the bottom region (its transcript
    #     fills the screen below), which otherwise mis-reads as idle.
    # Compute this FIRST so it gates the content-prone error/picker checks below:
    # a working frame must never be mistaken for an error or a prompt.
    #
    # None of these count while Claude's IDLE-at-prompt footer is showing: a live
    # spinner/meter and a QUOTED one are textually identical, so the robust tell is
    # that the idle prompt ("? for shortcuts") is only present when the session is
    # waiting for input -- a real working frame (foreground OR a running agents
    # panel) never shows it. Gating the whole signal on `not idle_prompt` kills the
    # meter-quote false positives (a pasted status line, a README blockquote, this
    # repo's own fixtures) whether they land in the bottom region or higher up.
    idle_prompt = any(p in footer for p in _IDLE_FOOTER)
    live_work = (not idle_prompt) and (
                any(p in busy_tail for p in _patterns["busy"])
                or bool(_WORKING_METER_RE.search(busy_tail))
                or bool(_LIVE_SPINNER_RE.search(full)))
    # Background work (a dynamic workflow / agents / a tool still running) keeps
    # the session "working" even though the foreground turn ended and the prompt is
    # idle. Its banner is a live line that clears on completion, so -- unlike the
    # quote-prone spinner/meter -- it is read over the whole screen and is NOT
    # gated on the idle prompt (which shows WHILE the background work runs).
    bg_work = bool(_BG_WORK_RE.search(full))
    busy_now = live_work or bg_work

    # Strong, specific error strings win even mid-stream (a genuine API error
    # replaces the spinner). Content-prone error phrases match ONLY in the tight
    # bottom region AND never while the meter shows work in progress -- otherwise
    # the meter's own digits (e.g. "↓ 500 tokens") or a number on screen would
    # read as a false HTTP error that then nags every 5s.
    if any(p in tail for p in _patterns["error"]):
        return ("error", "error")
    if not busy_now and any(p in busy_tail for p in _patterns.get("error_footer", [])):
        return ("error", "error")
    if any(p in tail for p in _patterns["waiting"]):
        return ("waiting", "specific")
    # A genuine picker is NOT generating: the live "esc to interrupt" / meter hint
    # wins over generic picker words that may be incidental near the bottom.
    if not busy_now and any(p in footer for p in _patterns.get("waiting_footer", [])):
        return ("waiting", "footer")
    if busy_now:
        return ("working", "busy")
    return ("idle", "idle")

# --------------------------------------------------------------------------- #
# Locate the real `claude` (avoid recursing into this wrapper)
# --------------------------------------------------------------------------- #
def real_claude():
    explicit = os.environ.get("CLAUDE_REAL")
    if explicit and os.path.exists(explicit):
        return explicit
    me = os.path.realpath(sys.argv[0])
    wrapper = os.path.realpath(__file__)
    for d in os.environ.get("PATH", "").split(os.pathsep):
        cand = os.path.join(d, "claude")
        if not (os.path.isfile(cand) and os.access(cand, os.X_OK)):
            continue
        rp = os.path.realpath(cand)
        if rp == me or rp == wrapper:
            continue
        # Skip our own shim (a tiny script that calls claude-mate-wrap) so a
        # `claude` shim earlier on PATH can't cause infinite double-wrapping.
        try:
            if os.path.getsize(cand) < 8192:
                with open(cand, "rb") as fh:
                    if b"claude-mate-wrap" in fh.read():
                        continue
        except OSError:
            pass
        return cand
    # Last resort: the canonical install dir, so the wrapper still finds the real
    # binary even when EVERY `claude` on PATH (incl. ~/.local/bin/claude) is our
    # shim. Pick the newest version directory's executable.
    vdir = os.path.expanduser("~/.local/share/claude/versions")
    try:
        for v in sorted(os.listdir(vdir), reverse=True):
            cand = os.path.join(vdir, v)
            if os.path.isfile(cand) and os.access(cand, os.X_OK):
                return cand
    except OSError:
        pass
    return None  # not found -- caller must handle (NEVER fall back to a bare
                 # "claude": in a global-shim deploy that re-execs THIS wrapper
                 # -> infinite re-exec loop, esp. on the pyte-missing path).

def exec_real_claude(extra_argv):
    """exec the real claude (skipping this shim) with our argv, or exit cleanly if
    it can't be located. Never execs a bare "claude" -- that would re-enter the
    wrapper and, when pyte is missing, spin forever."""
    rc = real_claude()
    if not rc:
        sys.stderr.write("[claude-mate-wrap] could not locate the real `claude` "
                         "binary; set CLAUDE_REAL=/path/to/claude.\n")
        os._exit(127)
    os.execvp(rc, ["claude"] + extra_argv)
    os._exit(127)

# --------------------------------------------------------------------------- #
# Main
# --------------------------------------------------------------------------- #
def main():
    # pyte is required to mirror the TUI; without it we cannot wrap. Run the real
    # claude unwrapped via real_claude() (which skips THIS shim) -- never bare
    # "claude", which in the global-shim deployment would re-exec the wrapper
    # forever (the import-time fallback's old bug).
    if pyte is None:
        sys.stderr.write("[claude-mate-wrap] pyte not installed (pip install pyte); "
                         "running claude unwrapped.\n")
        exec_real_claude(sys.argv[1:])

    # Non-interactive (piped / scripted) use: don't wrap, just be claude. This
    # keeps a global `claude` shim safe for `claude -p ...`, CI, pipes, etc.
    if not (sys.stdin.isatty() and sys.stdout.isatty()):
        exec_real_claude(sys.argv[1:])

    rows, cols = get_winsize(sys.stdin.fileno())

    pid, master_fd = pty.fork()
    if pid == 0:
        # Child: become the real claude.
        exec_real_claude(sys.argv[1:])

    # Parent.
    set_winsize(master_fd, rows, cols)
    # Non-blocking writes to the child's PTY (#3). A large paste while claude is
    # busy can fill the PTY input buffer; a BLOCKING os.write(master_fd, ...) would
    # then stall the relay -> the wrapper stops draining claude's output -> claude
    # blocks on ITS write -> two-way deadlock. With the fd non-blocking we buffer
    # the remainder (`pend`) and flush it when select() reports master_fd writable.
    # Reads become non-blocking too, so master-side reads guard for BlockingIOError.
    os.set_blocking(master_fd, False)

    # Set our unique terminal title (for focus matching) — harmless if ignored.
    try:
        sys.stdout.write(f"\033]0;{TITLE}\007")
        sys.stdout.flush()
    except Exception:
        pass

    screen = pyte.Screen(cols, rows)
    stream = pyte.ByteStream(screen)
    screen_lock = threading.Lock()

    state = {"cur": "idle", "reported": None, "pending": None,
             "pending_src": "idle", "since": 0.0, "last_sent": 0.0,
             "meta_reported": ("", "")}
    dbg = open(DEBUG, "a") if DEBUG else None

    def evaluate():
        with screen_lock:
            text = "\n".join(screen.display)
        parse_meta(text)                       # refresh cached model/effort
        new, src = detect_state(text)
        now = time.monotonic()
        if new != state["pending"]:
            state["pending"] = new
            state["since"] = now
        state["pending_src"] = src             # latest source governs the hold
        # A footer-only "waiting" must persist longer than a normal transition
        # so a config dialog you open and dismiss (/effort, /model) never reports.
        hold = (WAITING_FOOTER_DEBOUNCE_S
                if (state["pending"] == "waiting" and src == "footer")
                else DEBOUNCE_S)
        # Promote a pending state once it has been stable long enough.
        if state["pending"] != state["cur"] and (now - state["since"]) >= hold:
            state["cur"] = state["pending"]
        # Report on a state change, when model/effort first become known (or
        # change), or as a periodic keepalive.
        meta = (g_meta["model"], g_meta["effort"])
        if (state["cur"] != state["reported"] or meta != state["meta_reported"]
                or (now - state["last_sent"]) >= KEEPALIVE_S):
            state["reported"] = state["cur"]
            state["meta_reported"] = meta
            state["last_sent"] = now
            send_daemon(state["cur"])
            if dbg:
                dbg.write(f"\n===== {time.strftime('%H:%M:%S')} state={state['cur']} "
                          f"model={meta[0]!r} effort={meta[1]!r} =====\n")
                dbg.write(text + "\n")
                dbg.flush()

    # SIGWINCH handling -- keep PTY + emulator sized to the real terminal.
    #
    # The terminal sends SIGWINCH on every resize (and many emulators raise it
    # when you open/split a tab as the layout reflows). Python delivers signals
    # on the MAIN thread, between bytecodes -- so a handler that takes
    # `screen_lock` can SELF-DEADLOCK: if the resize lands while the main loop
    # is inside `with screen_lock: stream.feed(...)` (very likely during heavy
    # output) the handler runs on that same thread and blocks forever trying to
    # re-acquire a non-reentrant lock the thread already holds. That froze the
    # whole session on resize / new-tab, forcing a kill (and losing output).
    #
    # Fix: the handler does only what is async-signal-safe -- flip a flag (a
    # single store) -- and `set_wakeup_fd` pokes a self-pipe so a blocked
    # select() returns promptly. The ACTUAL resize (ioctl + pyte) runs back in
    # the main loop, OUTSIDE signal context, where taking the lock is safe.
    winch_pending = [False]
    wake_r, wake_w = os.pipe()
    os.set_blocking(wake_r, False)
    os.set_blocking(wake_w, False)

    def on_winch(signum, frame):
        winch_pending[0] = True       # async-signal-safe: just flag it
    signal.signal(signal.SIGWINCH, on_winch)
    try:
        # Make any signal wake select() (main thread only); drop the byte if the
        # pipe ever backs up rather than spamming stderr.
        signal.set_wakeup_fd(wake_w, warn_on_full_buffer=False)
    except (ValueError, OSError, TypeError):
        pass

    def apply_resize():
        r, c = get_winsize(sys.stdin.fileno())
        set_winsize(master_fd, r, c)          # resize PTY -> child claude reflows
        with screen_lock:
            try:
                screen.resize(r, c)           # keep the emulator in step
            except Exception:
                pass

    threading.Thread(target=ctrl_listener, daemon=True).start()
    send_daemon("idle")  # register immediately on launch

    # Periodic evaluator (catches quiescence after output stops). `_running` lets
    # cleanup() stop it BEFORE it sends the final 'end', so the monitor can't fire
    # a keepalive/state report afterwards and re-register the just-ended session
    # (a ghost the daemon would then keep alive via last_update_ts).
    _running = [True]
    def monitor():
        while _running[0]:
            time.sleep(POLL_MS)
            if not _running[0]:
                break
            try:
                load_patterns()   # hot-reload tuning without a restart
                evaluate()
            except Exception:
                pass
    threading.Thread(target=monitor, daemon=True).start()

    old = None
    try:
        old = termios.tcgetattr(sys.stdin)
        tty.setraw(sys.stdin.fileno())
    except Exception:
        old = None

    # --- Single cleanup path, run on normal exit AND on external termination ---
    # Previously ALL teardown lived in the `finally` below, which `kill`, logout
    # (SIGHUP) or a `kill -QUIT` skip by default -> the shell came back with no
    # echo / no line editing (blind `reset` needed), the daemon kept showing the
    # dead session for up to its TTL, and the ctrl socket leaked. Now one
    # idempotent cleanup() restores the tty, tells the daemon, and unlinks the
    # socket -- registered via atexit and the TERM/HUP/QUIT handlers below.
    _cleaned = [False]
    def cleanup():
        if _cleaned[0]:
            return
        _cleaned[0] = True
        _running[0] = False                             # stop the monitor (no post-end report)
        try:
            signal.set_wakeup_fd(-1)
        except Exception:
            pass
        # CRITICAL teardown FIRST -- deregister and drop the socket before any
        # terminal-touching step, so a wedged / flow-controlled (Ctrl-S) terminal
        # can never leave a ghost session behind: the 'end' must always get out.
        send_daemon("end")                              # deregister this session
        try:
            if os.path.exists(CTRL_SOCK):
                os.unlink(CTRL_SOCK)
        except OSError:
            pass
        # Hang up the child's PTY. If the relay broke while claude was still alive
        # (e.g. our output terminal vanished), closing the master sends the child
        # EOF/SIGHUP so it exits and the waitpid below can reap it instead of
        # blocking forever.
        try:
            os.close(master_fd)
        except OSError:
            pass
        for _fd in (wake_r, wake_w):
            try:
                os.close(_fd)
            except OSError:
                pass
        if dbg:
            try:
                dbg.close()
            except Exception:
                pass
        # Restore the tty with TCSANOW (apply immediately). TCSADRAIN/TCSAFLUSH
        # would BLOCK until the terminal's output queue drains -- exactly the
        # wedged-terminal case this teardown must survive -- so they are wrong here.
        if old is not None:
            try:
                termios.tcsetattr(sys.stdin, termios.TCSANOW, old)
            except Exception:
                pass
        # Cosmetic title reset LAST and NON-BLOCKING: if the terminal's output
        # buffer is full (no reader / Ctrl-S), a blocking write here would hang the
        # entire exit. Best-effort only -- it must never stall teardown.
        try:
            ofd = sys.stdout.fileno()
            fl = fcntl.fcntl(ofd, fcntl.F_GETFL)
            fcntl.fcntl(ofd, fcntl.F_SETFL, fl | os.O_NONBLOCK)
            try:
                os.write(ofd, b"\033]0;\007")           # clear our title (#13)
            except OSError:
                pass
            fcntl.fcntl(ofd, fcntl.F_SETFL, fl)
        except Exception:
            pass

    def _on_term(signum, frame):
        # External termination: run the same teardown as a clean exit, then
        # re-raise the signal's default disposition so our exit status is correct
        # and the child gets reaped. cleanup() never takes screen_lock, so (unlike
        # the old SIGWINCH bug) running it from a signal handler can't deadlock.
        cleanup()
        try:
            signal.signal(signum, signal.SIG_DFL)
            os.kill(os.getpid(), signum)
        except Exception:
            os._exit(128 + signum)

    for _sig in (signal.SIGTERM, signal.SIGHUP, signal.SIGQUIT):
        try:
            signal.signal(_sig, _on_term)
        except (ValueError, OSError):
            pass
    atexit.register(cleanup)

    # Bytes queued for the child's PTY (master_fd), drained NON-BLOCKING so a big
    # paste can never stall the relay (#3).
    pend = bytearray()
    def flush_to_child():
        """Push as much of `pend` to the child as the PTY will accept right now.
        Returns False on a fatal write error (caller should exit)."""
        while pend:
            try:
                n = os.write(master_fd, pend)
            except BlockingIOError:
                return True          # PTY input full; keep remainder, retry on writable
            except OSError:
                return False         # child / PTY gone
            if n <= 0:
                return True
            del pend[:n]
        return True

    out_fd = sys.stdout.fileno()
    def write_all_stdout(buf):
        """Write the WHOLE buffer to stdout, looping on the returned count. stdout
        stays blocking, but a write interrupted by a signal (e.g. SIGWINCH) after
        transferring some bytes returns a SHORT count -- CPython only auto-retries
        an EINTR that moved zero bytes -- so a single os.write could silently drop
        the tail (corrupting the visible TUI while pyte still sees the full buffer).
        Returns False on a fatal terminal error (caller should exit)."""
        mv = memoryview(buf)
        while mv:
            try:
                n = os.write(out_fd, mv)
            except InterruptedError:
                continue
            except OSError:
                return False
            if n <= 0:
                return False
            mv = mv[n:]
        return True

    stdin_fd = sys.stdin.fileno()
    stdin_open = True
    try:
        while True:
            # Apply any resize requested by the SIGWINCH handler, on THIS thread
            # (never inside the signal handler -> no self-deadlock on screen_lock).
            if winch_pending[0]:
                winch_pending[0] = False
                try:
                    apply_resize()
                except Exception:
                    pass

            rset = [master_fd, wake_r]
            if stdin_open:
                rset.append(stdin_fd)
            wset = [master_fd] if pend else []   # only wait for writable with a backlog
            try:
                # The self-pipe (set_wakeup_fd) normally wakes us instantly on a
                # SIGWINCH. The 1s timeout is a belt-and-suspenders fallback: if
                # set_wakeup_fd is ever unavailable, a pending resize is still
                # applied (top of loop) within ~1s instead of never -- without
                # busy-waiting when idle.
                r, w, _ = select.select(rset, wset, [], 1.0)
            except (OSError, select.error):
                break

            if wake_r in r:
                # Drain the signal-wakeup pipe; the winch flag (checked at the
                # top of the loop) carries the actual intent.
                try:
                    while os.read(wake_r, 4096):
                        pass
                except OSError:
                    pass

            if stdin_open and stdin_fd in r:
                try:
                    data = os.read(stdin_fd, 4096)
                except OSError:
                    data = b""
                if not data:
                    # stdin EOF (#7): stop selecting on it. The OLD loop only
                    # forwarded `if data:` and never dropped stdin, so after EOF
                    # select reported it readable forever -> 100% CPU busy-spin
                    # (e.g. under nohup/disown where SIGHUP doesn't kill). We keep
                    # relaying the child's output until the child itself exits.
                    stdin_open = False
                else:
                    pend += data
                    if not flush_to_child():
                        break

            if pend and master_fd in w:
                if not flush_to_child():
                    break

            if master_fd in r:
                try:
                    out = os.read(master_fd, 8192)
                except BlockingIOError:
                    out = None                 # spurious readable; nothing to do
                except OSError:
                    break
                if out == b"":
                    break                      # child closed the PTY -> exit
                if out:
                    if not write_all_stdout(out):      # full, partial-safe passthrough (#5)
                        break                  # terminal gone: exit so we reap the child
                    with screen_lock:
                        try:
                            stream.feed(out)   # mirror into the emulator
                        except Exception:
                            pass
            # State evaluation is the monitor thread's job ONLY (sole evaluator, #9):
            # no inline evaluate() here, so the two threads can't race the `state`
            # dict / debounce or tear a g_meta read. The monitor re-evaluates every
            # POLL_MS, which is plenty responsive for an away-from-keyboard alert.
    finally:
        cleanup()

    # Propagate claude's exit code. cleanup() has already closed master_fd, so a
    # child still alive on an abnormal break path gets SIGHUP and exits; we poll
    # briefly, then escalate to SIGKILL so the wrapper can NEVER block here forever
    # (the old unconditional os.waitpid(pid, 0) hung if the child ignored the
    # hangup). SystemExit from sys.exit() is not an Exception, so it propagates.
    try:
        for _ in range(50):                             # ~5s grace
            wpid, status = os.waitpid(pid, os.WNOHANG)
            if wpid:
                sys.exit(os.waitstatus_to_exitcode(status))
            time.sleep(0.1)
        try:
            os.kill(pid, signal.SIGKILL)
        except OSError:
            pass
        _, status = os.waitpid(pid, 0)
        sys.exit(os.waitstatus_to_exitcode(status))
    except Exception:
        sys.exit(0)

if __name__ == "__main__":
    main()
